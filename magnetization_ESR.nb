  RowBox[{
   RowBox[{"test", "[", 
    RowBox[{"t_", ",", " ", "\[Omega]L_"}], "]"}], "=", 
   RowBox[{"InverseFourierTransform", "[", 
    RowBox[{
     RowBox[{"1", "/", 
      RowBox[{"(", 
