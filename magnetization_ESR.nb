Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"FourierTransform", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{
       RowBox[{"-", "\[CapitalOmega]"}], " ", "t"}], "]"}], " ", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", " ", "t"}], "/", "T2"}], "]"}], " ", 
     RowBox[{"HeavisideTheta", "[", "t", "]"}]}], ",", " ", "t", ",", 
    "\[Omega]", ",", "  ", 
    RowBox[{"FourierParameters", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", " ", "1"}], "}"}]}], ",", " ", 
    RowBox[{"Assumptions", "\[Rule]", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[CapitalOmega]", " ", "\[Element]", " ", "Reals"}], ",", " ", 
       RowBox[{"T2", ">", " ", "0"}]}], "}"}]}]}], " ", "]"}], " ", "//", 
  "Simplify"}]], "Input",
