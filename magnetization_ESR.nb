     RowBox[{"T2", " ", "\[Omega]"}]}], ")"}]}], 
  RowBox[{"2", " ", "\[Pi]", " ", 
   RowBox[{"(", 
    RowBox[{"\[ImaginaryI]", "+", 
     RowBox[{"T2", " ", 
      RowBox[{"(", 
       RowBox[{"\[Omega]", "-", "\[CapitalOmega]"}], ")"}]}]}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{"\[ImaginaryI]", "+", 
     RowBox[{"T2", " ", 
      RowBox[{"(", 
       RowBox[{"\[Omega]", "+", "\[CapitalOmega]"}], ")"}]}]}], 
    ")"}]}]]], "Output",
