        RowBox[{"-", "1"}], ",", " ", "1"}], "}"}]}], ",", " ", 
     RowBox[{"Assumptions", "\[Rule]", " ", 
      RowBox[{"A", ">", "0"}]}]}], " ", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
